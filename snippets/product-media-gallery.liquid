{%- comment -%}
  Giftbu Custom Product Media Gallery
  Usage: {% render 'product-media-gallery' %}
{%- endcomment -%}

{{ 'section-product-media-gallery.css' | asset_url | stylesheet_tag }}
<script src="{{ 'section-product-media-gallery.js' | asset_url }}" defer="defer"></script>

<div id="GsMediaGallery-{{ section.id }}" class="gs-media-gallery">
  <!-- Thumbnails (Left Column) -->
  <div class="gs-media-gallery__thumbnails">
    <ul class="gs-thumbnail-list" role="list">
      {%- for media in product.media -%}
        <li class="gs-thumbnail-list__item">
          <button
            class="gs-thumbnail-btn {% if forloop.first %}is-active{% endif %}"
            data-target="GsSlide-{{ section.id }}-{{ media.id }}"
            aria-label="{{ 'products.product.media.load_image' | t: index: forloop.index }}"
          >
            {{ media.preview_image | image_url: width: 150 | image_tag: loading: 'lazy', class: 'gs-thumbnail-img' }}
          </button>
        </li>
      {%- endfor -%}
    </ul>

    <!-- Personalization Preview Thumbnail Placeholder -->
    <div id="gs-pers-gallery-thumb-wrap" class="gs-pers-thumb-wrap" hidden>
      <hr class="gs-pers-separator">
      <button
        type="button"
        class="gs-thumbnail-btn"
        id="gs-pers-gallery-thumb-btn"
        data-target="GsSlide-pers-preview"
        aria-label="View personalized preview"
      >
        <img id="gs-pers-gallery-thumb-img" class="gs-thumbnail-img" src="" alt="Personalized preview" loading="lazy">
      </button>
    </div>
  </div>

  <!-- Main Viewer (Right Column) -->
  <div class="gs-media-gallery__main">
    <ul class="gs-main-list" role="list">
      {%- for media in product.media -%}
        <li
          id="GsSlide-{{ section.id }}-{{ media.id }}"
          class="gs-main-list__item {% if forloop.first %}is-active{% endif %}"
          data-media-id="{{ media.id }}"
        >
          {%- if media.media_type == 'image' -%}
            {{
              media.preview_image
              | image_url: width: 1200
              | image_tag: loading: 'lazy', class: 'gs-main-img', alt: media.alt
              | escape
            }}
          {%- else -%}
            <div class="gs-main-media-container">
              {{
                media
                | media_tag: image_size: '1024x', autoplay: true, loop: true, controls: true, class: 'gs-main-media-tag'
              }}
            </div>
          {%- endif -%}
        </li>
      {%- endfor -%}

      <!-- Personalization Preview Main Image Placeholder -->
      <li id="GsSlide-pers-preview" class="gs-main-list__item" data-media-id="pers-preview" hidden>
        <img id="gs-pers-gallery-main-img" class="gs-main-img" src="" alt="Personalized preview main" loading="lazy">
      </li>
    </ul>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const gallery = document.getElementById('GsMediaGallery-{{ section.id }}');
    if (!gallery) return;

    // 1. Handle Thumbnail Clicks
    gallery.addEventListener('click', (e) => {
      const btn = e.target.closest('.gs-thumbnail-btn');
      if (!btn) return;

      const targetId = btn.getAttribute('data-target');
      if (!targetId) return;

      gallery.querySelectorAll('.gs-thumbnail-btn').forEach((b) => b.classList.remove('is-active'));
      gallery.querySelectorAll('.gs-main-list__item').forEach((slide) => {
        slide.classList.remove('is-active');
        if (slide.id === 'GsSlide-pers-preview') slide.setAttribute('hidden', '');
      });

      btn.classList.add('is-active');
      const targetSlide = document.getElementById(targetId);

      if (targetSlide) {
        targetSlide.classList.add('is-active');
        targetSlide.removeAttribute('hidden');
      }
    });

    // 2. Sync Gallery with Variant Selection Change
    document.addEventListener('change', (e) => {
      if (e.target.matches('.gs-variant-radio')) {
        // Wait briefly for Dawn's variant-select JS to update the JSON script block
        setTimeout(() => {
          const variantDataTag = document.querySelector('variant-selects [data-selected-variant]');
          if (!variantDataTag) return;

          try {
            const variant = JSON.parse(variantDataTag.textContent);
            if (variant && variant.featured_media) {
              const mediaId = variant.featured_media.id;
              const targetBtn = gallery.querySelector(`[data-target="GsSlide-{{ section.id }}-${mediaId}"]`);
              if (targetBtn) {
                targetBtn.click(); // Trigger the exact same logic as a manual thumbnail click
              }
            }
          } catch (err) {
            console.error('Error parsing variant JSON', err);
          }
        }, 50);
      }
    });
  });
</script>
