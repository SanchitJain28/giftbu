{%- unless product.has_only_default_variant -%}
  {{ 'component-product-variant-picker.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'component-product-variant-picker.js' | asset_url }}" defer="defer"></script>

  <variant-selects
    id="variant-selects-{{ section.id }}"
    data-section="{{ section.id }}"
    {{ block.shopify_attributes }}
  >
    {%- for option in product.options_with_values -%}
      <fieldset class="js product-form__input gs-variant-fieldset">
        <legend class="form__label gs-variant-label">{{ option.name }}</legend>

        <div class="gs-variant-carousel" id="gs-variant-carousel-{{ option.position }}">
          <!-- Previous Button -->
          <button type="button" class="gs-variant-nav gs-variant-nav--prev" aria-label="Previous variants">
            <svg viewBox="0 0 14 10" fill="none" class="icon icon-caret">
              <path fill-rule="evenodd" clip-rule="evenodd" d="M10.957 3.543 7 7.5 3.043 3.543l.914-.914L7 5.672l3.043-3.043.914.914Z" fill="currentColor"></path>
            </svg>
          </button>

          <!-- Carousel Track -->
          <div class="gs-variant-track">
            {%- for value in option.values -%}
              {%- liquid
                assign val_string = value.name | default: value

                # Find matching variant for image/price
                assign target_variant = blank
                for v in product.variants
                  if option.position == 1 and v.option1 == val_string
                    assign target_variant = v
                    break
                  elsif option.position == 2 and v.option2 == val_string
                    assign target_variant = v
                    break
                  elsif option.position == 3 and v.option3 == val_string
                    assign target_variant = v
                    break
                  endif
                endfor

                assign variant_image = target_variant.featured_media | default: product.featured_media
                assign variant_price = target_variant.price | money
              -%}

              <div class="gs-variant-slide">
                <input
                  type="radio"
                  id="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}"
                  name="{{ option.name }}"
                  value="{{ val_string | escape }}"
                  form="{{ product_form_id }}"
                  {% if option.selected_value == val_string %}
                    checked
                  {% endif %}
                  data-option-value-id="{{ value.id | default: val_string | escape }}"
                  class="gs-variant-radio visually-hidden"
                >
                <label for="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}" class="gs-variant-card">
                  <div class="gs-variant-card__image-wrap">
                    {{
                      variant_image
                      | image_url: width: 300
                      | image_tag: loading: 'lazy', class: 'gs-variant-card__img', alt: val_string
                    }}
                  </div>
                  <div class="gs-variant-card__info">
                    <span class="gs-variant-card__title">{{ val_string }}</span>
                    <span class="gs-variant-card__price">{{ variant_price }}</span>
                  </div>
                </label>
              </div>
            {%- endfor -%}
          </div>

          <!-- Next Button -->
          <button type="button" class="gs-variant-nav gs-variant-nav--next" aria-label="Next variants">
            <svg viewBox="0 0 14 10" fill="none" class="icon icon-caret">
              <path fill-rule="evenodd" clip-rule="evenodd" d="M10.957 3.543 7 7.5 3.043 3.543l.914-.914L7 5.672l3.043-3.043.914.914Z" fill="currentColor"></path>
            </svg>
          </button>
        </div>
      </fieldset>
    {%- endfor -%}

    <script type="application/json" data-selected-variant>
      {{ product.selected_or_first_available_variant | json }}
    </script>
  </variant-selects>
{%- endunless -%}
