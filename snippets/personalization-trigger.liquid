{% assign is_personalizable = product.metafields.custom.is_personalizable.value %}

{% if is_personalizable %}
  <button
    class="gs-pers-trigger"
    id="gs-pers-trigger"
    type="button"
    aria-label="Personalise {{ product.title }}"
    aria-haspopup="dialog">
    <svg
      width="18"
      height="18"
      viewBox="0 0 18 18"
      fill="none"
      aria-hidden="true">
      <path
        d="M13.5 2.25L15.75 4.5L6 14.25H3.75V12L13.5 2.25Z"
        stroke="currentColor"
        stroke-width="1.4"
        stroke-linecap="round"
        stroke-linejoin="round" />
    </svg>
    Personalise This Gift
  </button>
{% endif %}