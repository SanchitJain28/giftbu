{{ 'section-cart.css' | asset_url | stylesheet_tag }}
<script src="{{ 'section-cart.js' | asset_url }}" defer="defer"></script>

<div class="gs-cart-page">
  <div class="gs-cart-container {% if cart == empty %} is-empty{% endif %}">
    <div class="gs-cart-header">
      <h1 class="gs-cart-title">Shopping Cart</h1>
      <button type="button" class="gs-cart-location js-location-open">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor">
          <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
        </svg>
        Delivery to: <span class="gs-location-badge js-location-label">Choose location</span>
      </button>
    </div>

    <!-- Empty State -->
    <div class="gs-cart-empty">
      <div class="gs-cart-empty__icon">
        <svg width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <rect x="3" y="8" width="18" height="12" rx="2" ry="2"></rect>
          <path d="M12 8v12"></path>
          <path d="M11.5 8c0-2.5-2.5-4-5-4s-3.5 1.5-3.5 4v1h8.5V8z"></path>
          <path d="M12.5 8c0-2.5 2.5-4 5-4s3.5 1.5 3.5 4v1h-8.5V8z"></path>
        </svg>
      </div>
      <h2>Your cart is currently empty</h2>
      <p>Looks like you haven't made your choice yet. Let's find the perfect gift.</p>
      <a href="{{ routes.all_products_collection_url }}" class="btn-primary">CONTINUE SHOPPING</a>
    </div>

    <!-- Filled State -->
    <form action="{{ routes.cart_url }}" class="gs-cart-contents" method="post" id="cart">
      <div class="gs-cart-items-wrapper" id="main-cart-items" data-id="{{ section.id }}">
        <div class="js-contents">
          {%- if cart != empty -%}
            {%- for item in cart.items -%}
              <!-- Find the preview image URL first for later use -->
              {%- assign preview_img_url = blank -%}
              {%- for property in item.properties -%}
                {%- if property.first == '_Preview_Image' -%}
                  {%- assign preview_img_url = property.last -%}
                {%- endif -%}
              {%- endfor -%}

              <div class="gs-cart-item-row" id="CartItem-{{ item.index | plus: 1 }}">
                <div class="gs-cart-item-card">
                  <!-- Custom Loading Overlay -->
                  <div class="loading__spinner hidden">
                    <svg viewBox="0 0 24 24" fill="none" stroke="var(--color-accent-gold)" stroke-width="2">
                      <circle cx="12" cy="12" r="10" stroke-opacity="0.2"></circle>
                      <path d="M12 2a10 10 0 0 1 10 10"></path>
                    </svg>
                  </div>

                  <!-- 1. Media -->
                  <div class="gs-cart-item__media">
                    {% if section.settings.replace_cart_image and preview_img_url != blank %}
                      <img
                        src="{{ preview_img_url }}"
                        alt="Personalized Preview"
                        loading="lazy"
                        width="120"
                        height="120"
                      >
                    {% elsif item.image %}
                      <img
                        src="{{ item.image | image_url: width: 240 }}"
                        alt="{{ item.image.alt | escape }}"
                        loading="lazy"
                        width="120"
                        height="120"
                      >
                    {% endif %}
                  </div>

                  <!-- 2. Details -->
                  <div class="gs-cart-item__details">
                    <a href="{{ item.url }}" class="gs-cart-item__name">{{- item.product.title | escape -}}</a>

                    <!-- [RESTORED] Personalization Properties -->
                    {%- if item.properties.size != 0 -%}
                      {%- assign has_valid_properties = false -%}
                      {%- for property in item.properties -%}
                        {%- assign property_first_char = property.first | slice: 0 -%}
                        {%- if property.last != blank and property_first_char != '_' -%}
                          {%- assign has_valid_properties = true -%}
                          {%- break -%}
                        {%- endif -%}
                      {%- endfor -%}

                      {%- if has_valid_properties -%}
                        <div class="gs-cart-item__props-wrapper">
                          <div class="gs-cart-item__props-badge">
                            <svg
                              width="14"
                              height="14"
                              viewBox="0 0 24 24"
                              fill="none"
                              stroke="currentColor"
                              stroke-width="2"
                            >
                              <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                            </svg>
                            Personalized Gift
                          </div>

                          <dl class="gs-cart-item__props-list">
                            {%- for property in item.properties -%}
                              {%- assign property_first_char = property.first | slice: 0 -%}
                              {%- if property.last != blank and property_first_char != '_' -%}
                                <div class="gs-cart-prop">
                                  <dt class="gs-cart-prop__label">{{ property.first }}:</dt>
                                  <dd class="gs-cart-prop__value">
                                    {%- if property.last contains 'cloudinary.com' or property.last contains 'http' -%}
                                      <a
                                        href="{{ property.last }}"
                                        target="_blank"
                                        class="gs-cart-prop__img-link"
                                        title="Click to view full image"
                                      >
                                        <img
                                          src="{{ property.last }}"
                                          alt="Uploaded Image"
                                          class="gs-cart-prop__img"
                                          width="40"
                                          height="40"
                                          loading="lazy"
                                        >
                                      </a>
                                    {%- else -%}
                                      {{ property.last }}
                                    {%- endif -%}
                                  </dd>
                                </div>
                              {%- endif -%}
                            {%- endfor -%}
                          </dl>

                          {% if preview_img_url != blank %}
                            <a href="{{ preview_img_url }}" target="_blank" class="gs-cart-preview-link">
                              <svg
                                width="12"
                                height="12"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                              >
                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                                <circle cx="12" cy="12" r="3"></circle>
                              </svg>
                              View Custom Preview
                            </a>
                          {% endif %}
                        </div>
                      {%- endif -%}
                    {%- endif -%}
                  </div>

                  <!-- 3. Price & Qty -->
                  <div class="gs-cart-item__price-qty">
                    <div class="gs-cart-item__price">{{ item.final_line_price | money }}</div>

                    <div class="gs-cart-qty">
                      <button
                        type="button"
                        class="gs-cart-qty__btn"
                        data-action="minus"
                        data-line="{{ item.index | plus: 1 }}"
                      >
                        <svg width="10" height="2" viewBox="0 0 12 2" fill="currentColor">
                          <path d="M0 0h12v2H0z"/>
                        </svg>
                      </button>

                      <input
                        class="gs-cart-qty__input"
                        type="number"
                        name="updates[]"
                        value="{{ item.quantity }}"
                        min="0"
                        data-line="{{ item.index | plus: 1 }}"
                        id="Quantity-{{ item.index | plus: 1 }}"
                      >

                      <button
                        type="button"
                        class="gs-cart-qty__btn"
                        data-action="plus"
                        data-line="{{ item.index | plus: 1 }}"
                      >
                        <svg width="10" height="10" viewBox="0 0 12 12" fill="currentColor">
                          <path d="M5 0h2v12H5z"/><path d="M0 5h12v2H0z"/>
                        </svg>
                      </button>
                    </div>
                  </div>
                </div>

                <!-- 4. Actions -->
                <div class="gs-cart-item__actions">
                  <button
                    type="button"
                    class="gs-action-btn gs-wishlist-btn"
                    aria-label="Add to wishlist"
                    data-product-id="{{ item.product.id }}"
                    data-product-title="{{ item.product.title | escape }}"
                    data-product-image="{{ item.image | image_url: width: 300 }}"
                    data-product-url="{{ item.product.url }}"
                    data-product-price="{{ item.final_price | money }}"
                  >
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
                    </svg>
                  </button>

                  <button
                    type="button"
                    class="gs-action-btn gs-action-remove"
                    data-line="{{ item.index | plus: 1 }}"
                    aria-label="Remove"
                  >
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line>
                    </svg>
                  </button>
                </div>
              </div>
            {%- endfor -%}
          {%- endif -%}
        </div>
      </div>
    </form>
  </div>
</div>

{% schema %}
{
  "name": "Cart Items",
  "settings": [
    {
      "type": "checkbox",
      "id": "replace_cart_image",
      "label": "Replace product image with personalized preview",
      "default": true
    }
  ]
}
{% endschema %}
