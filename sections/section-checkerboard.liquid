{{ 'section-checkerboard.css' | asset_url | stylesheet_tag }}
<script src="{{ 'section-checkerboard.js' | asset_url }}" defer="defer"></script>

<div class="gs-checkerboard-section">
  <div class="gs-checkerboard-container">
    {%- for block in section.blocks -%}

      {%- liquid
        assign layout_class = 'gs-cb-pair--text-left'
        if block.settings.desktop_layout == 'image_left'
          assign layout_class = 'gs-cb-pair--image-left'
        endif
      -%}

      <div class="gs-cb-pair {{ layout_class }} reveal-checkerboard" {{ block.shopify_attributes }}>

        <!-- Text Square -->
        <div class="gs-cb-cell gs-cb-text-cell">
          <div class="gs-cb-text-content">
            {%- if block.settings.heading != blank -%}
              <h2 class="gs-cb-heading">{{ block.settings.heading }}</h2>
            {%- endif -%}

            {%- if block.settings.text != blank -%}
              <p class="gs-cb-text">{{ block.settings.text }}</p>
            {%- endif -%}

            {%- if block.settings.button_label != blank -%}
              <a href="{{ block.settings.button_link | default: '#' }}" class="gs-cb-btn">
                {{ block.settings.button_label }}
              </a>
            {%- endif -%}
          </div>
        </div>

        <!-- Image Square -->
        <div class="gs-cb-cell gs-cb-image-cell">
          {%- if block.settings.image != blank -%}
            {{
              block.settings.image | image_url: width: 1000 | image_tag: loading: 'lazy', class: 'gs-cb-image', widths: '400, 600, 800, 1000', alt: block.settings.image.alt | default: block.settings.heading
            }}
          {%- else -%}
            {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg gs-cb-image' }}
          {%- endif -%}
        </div>

      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
  {
    "name": "Checkerboard Features",
    "tag": "section",
    "class": "section-edge-to-edge",
    "settings": [],
    "blocks": [
      {
        "type": "feature_pair",
        "name": "Feature Pair",
        "settings": [
          {
            "type": "select",
            "id": "desktop_layout",
            "label": "Desktop Layout",
            "options": [
              {
                "value": "text_left",
                "label": "Text Left, Image Right"
              }, {
                "value": "image_left",
                "label": "Image Left, Text Right"
              }
            ],
            "default": "text_left"
          },
          {
            "type": "image_picker",
            "id": "image",
            "label": "Image",
            "info": "Image will automatically crop to a perfect square."
          },
          {
            "type": "text",
            "id": "heading",
            "label": "Heading",
            "default": "CORPORATE GIFTING"
          },
          {
            "type": "textarea",
            "id": "text",
            "label": "Text",
            "default": "Make a lasting impression on your clients and partners."
          }, {
            "type": "text",
            "id": "button_label",
            "label": "Button Label",
            "default": "SHOP NOW"
          }, {
            "type": "url",
            "id": "button_link",
            "label": "Button Link"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "Checkerboard Features",
        "blocks": [
          {
            "type": "feature_pair",
            "settings": {
              "desktop_layout": "text_left",
              "heading": "CORPORATE GIFTING",
              "text": "Make a lasting impression on your clients and partners."
            }
          }, {
            "type": "feature_pair",
            "settings": {
              "desktop_layout": "text_left",
              "heading": "FESTIVE GIFTING",
              "text": "Spread the joy of the season, perfect for celebrating any occasion."
            }
          }, {
            "type": "feature_pair",
            "settings": {
              "desktop_layout": "image_left",
              "heading": "EMPLOYEE APPRECIATION",
              "text": "Reward your team for their hard work and dedication."
            }
          }, {
            "type": "feature_pair",
            "settings": {
              "desktop_layout": "image_left",
              "heading": "JOINING KITS",
              "text": "Welcome new hires with a thoughtful onboarding gift."
            }
          }
        ]
      }
    ]
  }
{% endschema %}