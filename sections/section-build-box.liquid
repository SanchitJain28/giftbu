{{ 'section-build-box.css' | asset_url | stylesheet_tag }}
<script src="{{ 'section-build-box.js' | asset_url }}" defer="defer"></script>

{%- style -%}
  #shopify-section-{{ section.id }} .gs-build-box {
    {% if section.settings.bg_image != blank %}
      background-image: url('{{ section.settings.bg_image | image_url: width: 2000 }}');
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
    {% else %}
      background-color: #FFFFFF;
    {% endif %}
  }
{%- endstyle -%}

<div class="gs-build-box">
  <div class="gs-build-box__container">

    <!-- Left Image Column -->
    <div class="gs-build-box__image-col reveal-left">
      {%- if section.settings.image != blank -%}
        {{
          section.settings.image | image_url: width: 1000 | image_tag: loading: 'lazy', class: 'gs-build-box__img', widths: '400, 600, 800, 1000', alt: section.settings.heading | escape
        }}
      {%- else -%}
        {{ 'collection-2' | placeholder_svg_tag: 'gs-build-box__img placeholder-svg' }}
      {%- endif -%}
    </div>

    <!-- Right Text Column -->
    <div class="gs-build-box__text-col reveal-right">
      <div class="gs-build-box__content">
        {%- if section.settings.subheading != blank -%}
          <h3 class="gs-build-box__subheading">{{ section.settings.subheading }}</h3>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h2 class="gs-build-box__heading" style="color: {{ section.settings.heading_color }} !important;">
            {{ section.settings.heading }}
          </h2>
        {%- endif -%}

        {%- if section.settings.text != blank -%}
          <div class="gs-build-box__text">
            {{ section.settings.text }}
          </div>
        {%- endif -%}

        {%- if section.settings.button_label != blank -%}
          <a href="{{ section.settings.button_link | default: '#' }}" class="gs-build-box__btn">
            {{ section.settings.button_label }}
          </a>
        {%- endif -%}
      </div>
    </div>

  </div>
</div>

{% schema %}
  {
    "name": "Build Your Own Box",
    "tag": "section",
    "class": "section-build-box",
    "settings": [
      {
        "type": "image_picker",
        "id": "bg_image",
        "label": "Background Image",
        "info": "Optional. Sits completely behind the section. If left blank, background is white."
      },
      {
        "type": "image_picker",
        "id": "image",
        "label": "Main Left Image",
        "info": "Upload the image with the blue box and chocolates."
      },
      {
        "type": "text",
        "id": "subheading",
        "label": "Subheading",
        "default": "Can't decide what to gift?"
      },
      {
        "type": "text",
        "id": "heading",
        "label": "Main Heading",
        "default": "Build Your Own Box!"
      }, {
        "type": "color",
        "id": "heading_color",
        "label": "Heading Color",
        "default": "#1075B5"
      }, {
        "type": "richtext",
        "id": "text",
        "label": "Body Text",
        "default": "<p>With endless possibilities, you're the boss<br>(with a little help from our gifting experts).</p>"
      }, {
        "type": "text",
        "id": "button_label",
        "label": "Button Label",
        "default": "REQUEST A CALL BACK"
      }, {
        "type": "url",
        "id": "button_link",
        "label": "Button Link"
      }
    ],
    "presets": [
      {
        "name": "Build Your Own Box"
      }
    ]
  }
{% endschema %}