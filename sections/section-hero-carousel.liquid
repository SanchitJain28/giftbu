{{ 'section-hero-carousel.css' | asset_url | stylesheet_tag }}
<script src="{{ 'section-hero-carousel.js' | asset_url }}" defer="defer"></script>

<div id="gs-hero-carousel-{{ section.id }}" class="gs-hero-carousel-wrapper">
  <div class="gs-hero-carousel reveal-up page-width">
    <div class="gs-hero-carousel__inner">

      <!-- Track Container -->
      <div class="gs-hero-carousel__track-container">
        <div class="gs-hero-carousel__track" data-carousel-track>

          {%- for block in section.blocks -%}
            <div class="gs-hero-carousel__slide" {{ block.shopify_attributes }}>

              <div class="gs-hero-carousel__image-wrap">
                {%- if block.settings.image != blank -%}
                  {{ block.settings.image | image_url: width: 2000 | image_tag: loading: 'lazy', alt: block.settings.title, class: 'gs-hero-carousel__img' }}
                {%- else -%}
                  {{ 'lifestyle-1' | placeholder_svg_tag: 'gs-hero-carousel__img placeholder-svg' }}
                {%- endif -%}
              </div>

              <div class="gs-hero-carousel__content">
                {%- if block.settings.title != blank -%}
                  <h2 class="gs-hero-carousel__title">{{ block.settings.title }}</h2>
                {%- endif -%}

                {%- if block.settings.subtitle != blank -%}
                  <p class="gs-hero-carousel__subtitle">{{ block.settings.subtitle }}</p>
                {%- endif -%}

                {%- if block.settings.btn_text != blank -%}
                  <a href="{{ block.settings.btn_link | default: '#' }}" class="gs-hero-carousel__btn">
                    {{ block.settings.btn_text }}
                  </a>
                {%- endif -%}

                {%- if block.settings.bottom_text != blank -%}
                  <div class="gs-hero-carousel__bottom-text">{{ block.settings.bottom_text }}</div>
                {%- endif -%}
              </div>

            </div>
          {%- endfor -%}

        </div>
      </div>

      <!-- Pagination Dots -->
      <div class="gs-hero-carousel__pagination" data-carousel-pagination>
        {%- for block in section.blocks -%}
          <button
            class="gs-carousel-dot {% if forloop.first %}is-active{% endif %}"
            data-index="{{ forloop.index0 }}"
            aria-label="Go to slide {{ forloop.index }}"></button>
        {%- endfor -%}
      </div>

    </div>
  </div>
</div>

{% schema %}
  {
    "name": "Hero Carousel",
    "tag": "section",
    "class": "section",
    "settings": [],
    "blocks": [
      {
        "type": "slide",
        "name": "Slide",
        "limit": 10,
        "settings": [
          {
            "type": "image_picker",
            "id": "image",
            "label": "Background Image",
            "info": "Desktop Recommended: 1400x500px"
          },
          {
            "type": "text",
            "id": "title",
            "label": "Title",
            "default": "Balloon Décor For Every Party!"
          },
          {
            "type": "text",
            "id": "subtitle",
            "label": "Subtitle",
            "default": "Birthday, baby shower, anniversary & more decor designs"
          },
          {
            "type": "text",
            "id": "btn_text",
            "label": "Button Text",
            "default": "EXPLORE DECOR"
          },
          {
            "type": "url",
            "id": "btn_link",
            "label": "Button Link"
          },
          {
            "type": "text",
            "id": "bottom_text",
            "label": "Bottom Features Text",
            "default": "No Harmful Gas • 60-Min Setup by igp Experts • Same-Day Service"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "Hero Carousel",
        "blocks": [
          {
            "type": "slide"
          },
          {
            "type": "slide"
          },
          {
            "type": "slide"
          }
        ]
      }
    ]
  }
{% endschema %}