{% schema %}
{
  "name": "Global Header",
  "class": "section-header-wrapper",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo Image"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 50,
      "max": 250,
      "step": 5,
      "unit": "px",
      "label": "Logo Width (Desktop)",
      "default": 120
    },
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "checkbox",
      "id": "auto_menu",
      "label": "Auto-build menu",
      "default": true,
      "info": "Automatically shows all collections with products, plus essential pages. When disabled, uses the custom menu below."
    },
    {
      "type": "link_list",
      "id": "drawer_menu",
      "label": "Custom Menu (used when Auto-build is OFF)",
      "default": "main-menu"
    }
  ],
  "presets": [
    {
      "name": "Global Header"
    }
  ]
}
{% endschema %}

{{ 'section-header.css' | asset_url | stylesheet_tag }}
<script src="{{ 'section-header.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'section-wishlist.js' | asset_url }}" defer="defer"></script>

<header class="gs-header">
  <div class="gs-header__container">
    <!-- Left: Hamburger & Logo -->
    <div class="gs-header__left">
      <button class="gs-header__menu-btn js-drawer-open" aria-label="Open Menu">
        <i class="fa-solid fa-bars" style="font-size: 24px;"></i>
      </button>

      <a href="{{ routes.root_url }}" class="gs-header__logo">
        {%- if section.settings.logo != blank -%}
          {{
            section.settings.logo
            | image_url: width: 300
            | image_tag: alt: shop.name, class: 'gs-logo-img', style: 'width: __WIDTH__px;'
            | replace: '__WIDTH__', section.settings.logo_width
          }}
        {%- else -%}
          <span class="gs-header__logo-text">{{ shop.name }}</span>
        {%- endif -%}
      </a>

      <button class="gs-location-badge js-location-open" aria-label="Set delivery location">
        <span class="gs-location-badge__flag">🇮🇳</span>
        <span class="gs-location-badge__text">
          <span class="gs-location-badge__label js-location-label">Choose location</span>
        </span>
      </button>

      <nav class="gs-header__desktop-nav" aria-label="Main navigation">
        {%- for link in linklists[section.settings.drawer_menu].links -%}
          <div class="gs-desktop-nav__item{% if link.links != blank %} has-dropdown{% endif %}">
            <a href="{{ link.url }}" class="gs-desktop-nav__link">{{ link.title }}</a>
            {%- if link.links != blank -%}
              <div class="gs-desktop-nav__dropdown">
                {%- for childlink in link.links -%}
                  <a href="{{ childlink.url }}" class="gs-desktop-nav__dropdown-link">{{ childlink.title }}</a>
                {%- endfor -%}
              </div>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </nav>
    </div>

    <div class="gs-header__center">
      {% render 'gs-header-search' %}
    </div>

    <div class="gs-header__right">
      <a href="/pages/wishlist" class="gs-icon-link gs-icon-wishlist" aria-label="Wishlist">
        <i class="fa-regular fa-heart" style="font-size: 24px;"></i>
        <span class="gs-wishlist-count gs-cart-count" hidden>0</span>
      </a>

      <a href="{{ routes.cart_url }}" class="gs-icon-link gs-icon-cart" aria-label="Cart">
        <i class="fa-solid fa-cart-shopping" style="font-size: 24px;"></i>
        <div id="cart-icon-bubble">
          {% render 'cart-icon-bubble' %}
        </div>
      </a>

      <a
        href="{% if customer %}{{ routes.account_url }}{% else %}{{ routes.account_login_url }}{% endif %}"
        class="gs-icon-link"
        aria-label="Account"
      >
        <i class="fa-regular fa-user" style="font-size: 24px;"></i>
      </a>
    </div>
  </div>
</header>

<!-- Overlay -->
<div class="gs-menu-overlay js-drawer-overlay"></div>

<!-- Mega Drawer -->
<div class="gs-menu-drawer js-menu-drawer" aria-hidden="true">
  <div class="gs-drawer__header">
    <span class="gs-drawer__title">Menu</span>
    <button class="gs-drawer__close js-drawer-close" aria-label="Close Menu">
      <i class="fa-solid fa-xmark" style="font-size: 24px;"></i>
    </button>
  </div>

  <div class="gs-drawer__layout">
    <!-- Left panel: top collections + category list -->
    <div class="gs-drawer__panel-left">
      {%- if section.settings.auto_menu -%}
        <p class="gs-drawer__shop-by-label">Shop By:</p>

        <!-- Auto-built collection groups -->
        <ul class="gs-drawer__nav-list">
          {%- for collection in collections -%}
            {%- if collection.products_count > 0 -%}
              <li class="gs-drawer__nav-item js-mega-item" data-collection-handle="{{ collection.handle }}">
                <div class="gs-drawer__link-row">
                  <a href="{{ collection.url }}" class="gs-drawer__link">{{ collection.title }}</a>
                  <button class="gs-drawer__toggle-btn js-mega-toggle" aria-label="Open {{ collection.title }}">
                    <i class="fa-solid fa-chevron-right"></i>
                  </button>
                </div>
              </li>
            {%- endif -%}
          {%- endfor -%}

          <!-- Essential pages -->
          <li class="gs-drawer__nav-item gs-drawer__nav-divider">
            <span class="gs-drawer__section-label">Pages</span>
          </li>
          <li class="gs-drawer__nav-item">
            <div class="gs-drawer__link-row">
              <a href="/pages/about-us" class="gs-drawer__link">About Us</a>
            </div>
          </li>
          <li class="gs-drawer__nav-item">
            <div class="gs-drawer__link-row">
              <a href="/pages/contact" class="gs-drawer__link">Contact</a>
            </div>
          </li>
          <li class="gs-drawer__nav-item">
            <div class="gs-drawer__link-row">
              <a href="/pages/corporate-gifting" class="gs-drawer__link">Corporate Gifting</a>
            </div>
          </li>
        </ul>

      {%- else -%}
        <!-- Custom menu fallback -->
        <ul class="gs-drawer__nav-list">
          {%- if section.settings.drawer_menu.links == blank -%}
            <li class="gs-drawer__empty">Select a menu in header settings.</li>
          {%- else -%}
            {%- for link in section.settings.drawer_menu.links -%}
              <li class="gs-drawer__nav-item{% if link.links != blank %} js-mega-item{% endif %}">
                <div class="gs-drawer__link-row">
                  <a href="{{ link.url }}" class="gs-drawer__link">{{ link.title }}</a>
                  {%- if link.links != blank -%}
                    <button class="gs-drawer__toggle-btn js-mega-toggle" aria-label="Open {{ link.title }}">
                      <i class="fa-solid fa-chevron-right"></i>
                    </button>
                  {%- endif -%}
                </div>
              </li>
            {%- endfor -%}
          {%- endif -%}
        </ul>
      {%- endif -%}
    </div>

    <!-- Right panel: sub-items rendered here -->
    <div class="gs-drawer__panel-right js-drawer-panel-right" aria-live="polite">
      <div class="gs-drawer__panel-right-inner">
        {%- if section.settings.auto_menu -%}
          <!-- Sub-panels for each collection, hidden by default -->
          {%- for collection in collections -%}
            {%- if collection.products_count > 0 -%}
              <div class="gs-drawer__sub-panel" data-panel="{{ collection.handle }}">
                <ul class="gs-drawer__sub-panel-list">
                  {%- for product in collection.products limit: 20 -%}
                    <li>
                      <a href="{{ product.url }}" class="gs-drawer__sub-panel-link">
                        {{ product.title }}
                      </a>
                    </li>
                  {%- endfor -%}
                  <li class="gs-drawer__sub-panel-viewall">
                    <a href="{{ collection.url }}">View all in {{ collection.title }} →</a>
                  </li>
                </ul>
              </div>
            {%- endif -%}
          {%- endfor -%}
        {%- else -%}
          {%- for link in section.settings.drawer_menu.links -%}
            {%- if link.links != blank -%}
              <div class="gs-drawer__sub-panel" data-panel="{{ link.handle }}">
                <ul class="gs-drawer__sub-panel-list">
                  {%- for childlink in link.links -%}
                    <li>
                      <a href="{{ childlink.url }}" class="gs-drawer__sub-panel-link">{{ childlink.title }}</a>
                    </li>
                  {%- endfor -%}
                </ul>
              </div>
            {%- endif -%}
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>
  </div>
</div>
