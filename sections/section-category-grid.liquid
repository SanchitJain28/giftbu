{{ 'section-category-grid.css' | asset_url | stylesheet_tag }}
<script src="{{ 'section-category-grid.js' | asset_url }}" defer="defer"></script>

<div class="gs-category-grid">
  <div class="gs-category-grid__wrapper">

    <div class="gs-category-grid__list">
      {%- for block in section.blocks -%}
        <div class="gs-category-grid__item" {{ block.shopify_attributes }}>
          <a
            href="{{ block.settings.link | default: '#' }}"
            class="gs-category-grid__link"
            aria-label="Category Link">
            {%- if block.settings.image != blank -%}
              {{
                block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', class: 'gs-category-grid__image', widths: '400, 600, 800, 1000', alt: block.settings.image.alt | default: 'Category Image'
              }}
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'placeholder-svg gs-category-grid__placeholder' }}
            {%- endif -%}
          </a>
        </div>
      {%- endfor -%}
    </div>

    <!-- Bottom Heading with Divider Lines -->
    {%- if section.settings.heading != blank -%}
      <div class="gs-category-grid__heading-wrapper">
        <h2 class="gs-category-grid__heading">{{ section.settings.heading }}</h2>
      </div>
    {%- endif -%}

  </div>
</div>

{% schema %}
  {
    "name": "Category Image Grid",
    "tag": "section",
    "class": "section",
    "max_blocks": 5,
    "settings": [
      {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default": "WHAT DO WE HAVE FOR YOU?"
      }
    ],
    "blocks": [
      {
        "type": "category_item",
        "name": "Category Item",
        "settings": [
          {
            "type": "image_picker",
            "id": "image",
            "label": "Image"
          }, {
            "type": "url",
            "id": "link",
            "label": "Link destination"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "Category Image Grid",
        "blocks": [
          {
            "type": "category_item"
          },
          {
            "type": "category_item"
          },
          {
            "type": "category_item"
          },
          {
            "type": "category_item"
          }, {
            "type": "category_item"
          }
        ]
      }
    ]
  }
{% endschema %}