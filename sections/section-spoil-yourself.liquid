{{ 'section-spoil-yourself.css' | asset_url | stylesheet_tag }}
<script src="{{ 'section-spoil-yourself.js' | asset_url }}" defer="defer"></script>

<div id="gs-spoil-{{ section.id }}" class="gs-spoil-wrapper">
  <div class="gs-spoil page-width">

    <div class="gs-spoil__header reveal-up">
      {%- if section.settings.title != blank -%}
        <h2 class="gs-spoil__title">{{ section.settings.title }}</h2>
      {%- endif -%}
      {%- if section.settings.subtitle != blank -%}
        <p class="gs-spoil__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>

    <div class="gs-spoil__grid">
      {%- for block in section.blocks -%}
        <a
          href="{{ block.settings.link | default: '#' }}"
          class="gs-spoil__item gs-spoil-item-reveal"
          aria-label="{{ block.settings.title }}"
          {{ block.shopify_attributes }}>
          <div class="gs-spoil__img-wrap">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy', alt: block.settings.title, class: 'gs-spoil__img' }}
            {%- else -%}
              {{ 'collection-1' | placeholder_svg_tag: 'gs-spoil__img placeholder-svg' }}
            {%- endif -%}
          </div>
          <div class="gs-spoil__label">
            {{ block.settings.title }}
          </div>
        </a>
      {%- endfor -%}
    </div>

  </div>
</div>

{% schema %}
  {
    "name": "Spoil Yourself Masonry",
    "tag": "section",
    "class": "section",
    "settings": [
      {
        "type": "text",
        "id": "title",
        "label": "Heading",
        "default": "Spoil Yourself, Guilt-Free"
      },
      {
        "type": "text",
        "id": "subtitle",
        "label": "Subheading",
        "default": "Self-care gifts across cakes, snacks, lifestyle, and more"
      }
    ],
    "blocks": [
      {
        "type": "masonry_item",
        "name": "Grid Item",
        "limit": 6,
        "settings": [
          {
            "type": "image_picker",
            "id": "image",
            "label": "Item Image"
          },
          {
            "type": "text",
            "id": "title",
            "label": "Bottom Red Label",
            "default": "CATEGORY NAME"
          },
          {
            "type": "url",
            "id": "link",
            "label": "Link"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "Spoil Yourself Masonry",
        "blocks": [
          {
            "type": "masonry_item",
            "settings": {
              "title": "CHERISH SWEET SURPRISES"
            }
          },
          {
            "type": "masonry_item",
            "settings": {
              "title": "SAVOR WHOLESOME SNACKS"
            }
          },
          {
            "type": "masonry_item",
            "settings": {
              "title": "SELF-PAMPERING ESSENTIALS"
            }
          },
          {
            "type": "masonry_item",
            "settings": {
              "title": "ELEVATE YOUR WORKSPACE"
            }
          },
          {
            "type": "masonry_item",
            "settings": {
              "title": "UNLOCK CULINARY BLISS"
            }
          },
          {
            "type": "masonry_item",
            "settings": {
              "title": "JOURNAL YOUR THOUGHTS"
            }
          }
        ]
      }
    ]
  }
{% endschema %}