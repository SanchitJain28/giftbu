{{ 'section-featured-collections.css' | asset_url | stylesheet_tag }}
<script src="{{ 'section-featured-collections.js' | asset_url }}" defer="defer"></script>

<div id="gs-featured-collections-{{ section.id }}" class="gs-featured-collections-wrapper">
  <div class="gs-featured-collections reveal-up page-width">
    <div class="gs-featured-collections__container">
      {%- for block in section.blocks -%}
        <a
          href="{{ block.settings.link | default: '#' }}"
          class="gs-featured-collections__item gs-fc-item-reveal"
          aria-label="{{ block.settings.title }}"
          {{ block.shopify_attributes }}>
          <div class="gs-featured-collections__image-wrap">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 120 | image_tag: loading: 'lazy', alt: block.settings.title, class: 'gs-featured-collections__img' }}
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'gs-featured-collections__img placeholder-svg' }}
            {%- endif -%}
          </div>
          <span class="gs-featured-collections__title">{{ block.settings.title }}</span>
        </a>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
  {
    "name": "Featured Collections",
    "tag": "section",
    "class": "section",
    "settings": [],
    "blocks": [
      {
        "type": "collection",
        "name": "Collection Item",
        "limit": 10,
        "settings": [
          {
            "type": "image_picker",
            "id": "image",
            "label": "Collection Image",
            "info": "Transparent PNG recommended."
          },
          {
            "type": "text",
            "id": "title",
            "label": "Label",
            "default": "Collection Name"
          },
          {
            "type": "url",
            "id": "link",
            "label": "Link"
          }
        ]
      }
    ],
    "presets": [
      {
