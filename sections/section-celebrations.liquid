{{ 'section-celebrations.css' | asset_url | stylesheet_tag }}
<script src="{{ 'section-celebrations.js' | asset_url }}" defer="defer"></script>

<div id="gs-celebrations-{{ section.id }}" class="gs-celebrations-wrapper">
  <div class="gs-celebrations page-width">

    <div class="gs-celebrations__header reveal-up">
      {%- if section.settings.title != blank -%}
        <h2 class="gs-celebrations__title">{{ section.settings.title }}</h2>
      {%- endif -%}
      {%- if section.settings.subtitle != blank -%}
        <p class="gs-celebrations__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>

    <div class="gs-celebrations__grid">
      {%- for block in section.blocks -%}
        <a
          href="{{ block.settings.link | default: '#' }}"
          class="gs-celebrations__item gs-celebrations-item-reveal"
          aria-label="{{ block.settings.title }}"
          {{ block.shopify_attributes }}>
          <div class="gs-celebrations__image-wrap">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 300 | image_tag: loading: 'lazy', alt: block.settings.title, class: 'gs-celebrations__img' }}
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'gs-celebrations__img placeholder-svg' }}
            {%- endif -%}
          </div>
          <span class="gs-celebrations__label">{{ block.settings.title }}</span>
        </a>
      {%- endfor -%}
    </div>

  </div>
</div>

{% schema %}
  {
    "name": "Celebrations Grid",
    "tag": "section",
    "class": "section",
    "settings": [
      {
        "type": "text",
        "id": "title",
        "label": "Heading",
        "default": "Surprises for Every Celebration"
      },
      {
        "type": "text",
        "id": "subtitle",
        "label": "Subheading",
        "default": "Curated gift ideas for every occasion, big or small"
      }
    ],
    "blocks": [
      {
        "type": "category",
        "name": "Celebration Category",
        "limit": 6,
        "settings": [
          {
            "type": "image_picker",
            "id": "image",
            "label": "Category Image",
            "info": "Transparent PNG recommended."
          },
          {
            "type": "text",
            "id": "title",
            "label": "Label",
            "default": "Category Name"
          },
          {
            "type": "url",
            "id": "link",
            "label": "Link"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "Celebrations Grid",
        "blocks": [
          {
            "type": "category",
            "settings": {
              "title": "Delivery in 60 Mins"
            }
          },
          {
            "type": "category",
            "settings": {
              "title": "Birthday Gifts"
            }
          },
          {
            "type": "category",
            "settings": {
              "title": "Balloon Gifts & Decor"
            }
          },
          {
            "type": "category",
            "settings": {
              "title": "Anniversary Gifts"
            }
          },
          {
            "type": "category",
            "settings": {
              "title": "Wedding Gifts"
            }
          },
          {
            "type": "category",
            "settings": {
              "title": "House Warming"
            }
          }
        ]
      }
    ]
  }
{% endschema %}