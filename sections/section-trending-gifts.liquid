{{ 'section-trending-gifts.css' | asset_url | stylesheet_tag }}
<script src="{{ 'section-trending-gifts.js' | asset_url }}" defer="defer"></script>

<div class="gs-trending-gifts">
  <div class="gs-trending-gifts__wrapper page-width">

    {%- if section.settings.title != blank -%}
      <h2 class="gs-trending-gifts__title reveal-trending-title">{{ section.settings.title }}</h2>
    {%- endif -%}

    <div class="gs-trending-gifts__grid">
      {%- for block in section.blocks -%}
        <a
          href="{{ block.settings.link | default: '#' }}"
          class="gs-trending-card reveal-trending-card"
          {{ block.shopify_attributes }}>

          <!-- Card Image -->
          <div class="gs-trending-card__image-wrapper">
            {%- if block.settings.image != blank -%}
              {{
                block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', class: 'gs-trending-card__image', widths: '400, 600, 800', alt: block.settings.main_text | default: 'Trending Gift'
              }}
            {%- else -%}
              {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg gs-trending-card__image' }}
            {%- endif -%}
          </div>

          <!-- Text Overlay -->
          <div class="gs-trending-card__overlay">
            {%- if block.settings.script_text != blank -%}
              <span class="gs-trending-card__script">{{ block.settings.script_text }}</span>
            {%- endif -%}

            {%- if block.settings.main_text != blank -%}
              <span class="gs-trending-card__main">{{ block.settings.main_text }}</span>
            {%- endif -%}
          </div>

        </a>
      {%- endfor -%}
    </div>

  </div>
</div>

{% schema %}
  {
    "name": "Trending Gifts Grid",
    "tag": "section",
    "class": "section",
    "settings": [
      {
        "type": "text",
        "id": "title",
        "label": "Section Heading",
        "default": "Trending Gifts at The Gift Studio"
      }
    ],
    "blocks": [
      {
        "type": "gift_card",
        "name": "Gift Card",
        "settings": [
          {
            "type": "image_picker",
            "id": "image",
            "label": "Card Image",
            "info": "Images will automatically display as perfect squares (1:1)."
          }, {
            "type": "text",
            "id": "script_text",
            "label": "Script Text (Golden)",
            "default": "for your"
          }, {
            "type": "text",
            "id": "main_text",
            "label": "Main Text (White)",
            "default": "ONBOARDING"
          }, {
            "type": "url",
            "id": "link",
            "label": "Card Link"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "Trending Gifts Grid",
        "blocks": [
          {
            "type": "gift_card",
            "settings": {
              "script_text": "for your",
              "main_text": "ONBOARDING"
            }
          }, {
            "type": "gift_card",
            "settings": {
              "script_text": "for your",
              "main_text": "STAR PERFORMER"
            }
          }, {
            "type": "gift_card",
            "settings": {
              "script_text": "at your",
              "main_text": "CONFERENCES"
            }
          }
        ]
      }
    ]
  }
{% endschema %}