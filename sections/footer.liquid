{{ 'section-custom-footer.css' | asset_url | stylesheet_tag }}
<script src="{{ 'section-custom-footer.js' | asset_url }}" defer="defer"></script>

<footer class="gs-footer">
  <div class="page-width gs-footer__wrapper reveal-up">
    
    <!-- Top Row: Logo -->
    <div class="gs-footer__top">
      {%- if section.settings.logo != blank -%}
        <img src="{{ section.settings.logo | image_url: width: 400 }}" 
             alt="{{ shop.name }}" 
             class="gs-footer__logo" 
             loading="lazy" 
             width="{{ section.settings.logo.width }}" 
             height="{{ section.settings.logo.height }}">
      {%- else -%}
        <h2 class="gs-footer__logo-text">{{ shop.name }}</h2>
      {%- endif -%}
    </div>

    <!-- Main Grid -->
    <div class="gs-footer__grid">
      
      <!-- Column 1: Contact Info -->
      <div class="gs-footer__col gs-footer__col--contact">
        {%- if section.settings.phone != blank -%}
          <div class="gs-contact-item">
            <div class="gs-contact-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
            </div>
            <a href="tel:{{ section.settings.phone | remove: ' ' | remove: '-' }}">{{ section.settings.phone }}</a>
          </div>
        {%- endif -%}

        {%- if section.settings.email != blank -%}
          <div class="gs-contact-item">
            <div class="gs-contact-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
            </div>
            <a href="mailto:{{ section.settings.email }}">{{ section.settings.email }}</a>
          </div>
        {%- endif -%}
      </div>

      <!-- Column 2: Menu 1 -->
      <div class="gs-footer__col gs-footer__col--menu">
        {%- if section.settings.menu_1 != blank -%}
          <ul class="gs-footer-menu list-unstyled">
            {%- for link in section.settings.menu_1.links -%}
              <li><a href="{{ link.url }}">{{ link.title }}</a></li>
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </div>

      <!-- Column 3: Menu 2 -->
      <div class="gs-footer__col gs-footer__col--menu">
        {%- if section.settings.menu_2 != blank -%}
          <ul class="gs-footer-menu list-unstyled">
            {%- for link in section.settings.menu_2.links -%}
              <li><a href="{{ link.url }}">{{ link.title }}</a></li>
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </div>

      <!-- Column 4: Menu 3 -->
      <div class="gs-footer__col gs-footer__col--menu">
        {%- if section.settings.menu_3 != blank -%}
          <ul class="gs-footer-menu list-unstyled">
            {%- for link in section.settings.menu_3.links -%}
              <li><a href="{{ link.url }}">{{ link.title }}</a></li>
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </div>

      <!-- Column 5: Social -->
      <div class="gs-footer__col gs-footer__col--social">
        <p class="gs-social-title">{{ section.settings.social_title }}</p>
        <div class="gs-social-icons">
          {%- if section.settings.social_fb != blank -%}
            <a href="{{ section.settings.social_fb }}" target="_blank" rel="noopener" aria-label="Facebook">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
            </a>
          {%- endif -%}
          {%- if section.settings.social_ig != blank -%}
            <a href="{{ section.settings.social_ig }}" target="_blank" rel="noopener" aria-label="Instagram">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
            </a>
          {%- endif -%}
          {%- if section.settings.social_yt != blank -%}
            <a href="{{ section.settings.social_yt }}" target="_blank" rel="noopener" aria-label="YouTube">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33 2.78 2.78 0 0 0 1.94 2c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.33 29 29 0 0 0-.46-5.33z"></path><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"></polygon></svg>
            </a>
          {%- endif -%}
        </div>
      </div>

    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Custom Footer",
  "settings":[
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Footer Logo"
    },
    {
      "type": "header",
      "content": "Contact Info"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Phone Number",
      "default": "+91-89764-49556"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email Address",
      "default": "contact@thegiftstudio.com"
    },
    {
      "type": "header",
      "content": "Menus"
    },
    {
      "type": "link_list",
      "id": "menu_1",
      "label": "Menu Column 1"
    },
    {
      "type": "link_list",
      "id": "menu_2",
      "label": "Menu Column 2"
    },
    {
      "type": "link_list",
      "id": "menu_3",
      "label": "Menu Column 3"
    },
    {
      "type": "header",
      "content": "Social Media"
    },
    {
      "type": "text",
      "id": "social_title",
      "label": "Social Title",
      "default": "Follow us on"
    },
    {
      "type": "url",
      "id": "social_fb",
      "label": "Facebook Link"
    },
    {
      "type": "url",
      "id": "social_ig",
      "label": "Instagram Link"
    },
    {
      "type": "url",
      "id": "social_yt",
      "label": "YouTube Link"
    }
  ]
}
{% endschema %}