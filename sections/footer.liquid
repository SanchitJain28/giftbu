{% schema %}
{
  "name": "Custom Footer",
  "class": "section-custom-footer",
  "max_blocks": 30,
  "settings": [
    {
      "type": "header",
      "content": "1. Top Link Groups (Categories/Pages)"
    },
    {
      "type": "collection_list",
      "id": "excluded_collections",
      "label": "Collections to Exclude",
      "info": "Select any collections you want to hide from the auto-fetched list."
    },
    {
      "type": "checkbox",
      "id": "show_link_groups",
      "label": "Show Link Groups Section",
      "default": true
    },
    {
      "type": "header",
      "content": "Auto-Fetch Collections"
    },
    {
      "type": "checkbox",
      "id": "auto_fetch_collections",
      "label": "Auto-fetch collections and products",
      "info": "If enabled, this overrides the manual blocks below and automatically displays all store collections and their products.",
      "default": false
    },
    {
      "type": "range",
      "id": "auto_fetch_limit",
      "min": 3,
      "max": 20,
      "step": 1,
      "label": "Max products to show per collection",
      "default": 10
    },
    {
      "type": "header",
      "content": "2. Stats Section"
    },
    {
      "type": "checkbox",
      "id": "show_stats",
      "label": "Show Stats Section",
      "default": true
    },
    {
      "type": "text",
      "id": "stat_1_num",
      "label": "Stat 1 Number",
      "default": "400+"
    },
    {
      "type": "text",
      "id": "stat_1_text",
      "label": "Stat 1 Text",
      "default": "Cities having same day delivery"
    },
    {
      "type": "text",
      "id": "stat_2_num",
      "label": "Stat 2 Number",
      "default": "100+"
    },
    {
      "type": "text",
      "id": "stat_2_text",
      "label": "Stat 2 Text",
      "default": "Countries being served with happiness"
    },
    {
      "type": "text",
      "id": "stat_3_num",
      "label": "Stat 3 Number",
      "default": "5 Million+"
    },
    {
      "type": "text",
      "id": "stat_3_text",
      "label": "Stat 3 Text",
      "default": "Gift boxes delivered across the globe"
    },
    {
      "type": "header",
      "content": "3. Apps & Main Logo"
    },
    {
      "type": "image_picker",
      "id": "main_logo",
      "label": "Center Logo"
    },
    {
      "type": "text",
      "id": "apps_title",
      "label": "Apps Title",
      "default": "Download our app for a better experience !!"
    },
    {
      "type": "image_picker",
      "id": "app_store_img",
      "label": "App Store Image"
    },
    {
      "type": "url",
      "id": "app_store_link",
      "label": "App Store Link"
    },
    {
      "type": "image_picker",
      "id": "play_store_img",
      "label": "Play Store Image"
    },
    {
      "type": "url",
      "id": "play_store_link",
      "label": "Play Store Link"
    },
    {
      "type": "text",
      "id": "social_title",
      "label": "Social Media Title",
      "default": "Follow us on:"
    },
    {
      "type": "header",
      "content": "4. Copyright & Payments"
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright Text",
      "default": "Copyright © 2000-2024. All rights reserved."
    },
    {
      "type": "checkbox",
      "id": "show_payments",
      "label": "Show Payment Methods",
      "default": true
    },
    {
      "type": "text",
      "id": "payment_title",
      "label": "Payment Title",
      "default": "Payment Methods:"
    }
  ],
  "blocks": [
    {
      "type": "link_group",
      "name": "Link Group",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Group Title (e.g. Know About Us:)",
          "default": "Collection Name:"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Choose Menu (Overrides manual links below)"
        },
        {
          "type": "header",
          "content": "Or Add Manual Links"
        },
        { "type": "text", "id": "link_1_text", "label": "Link 1 Text" },
        { "type": "url", "id": "link_1_url", "label": "Link 1 URL" },
        { "type": "text", "id": "link_2_text", "label": "Link 2 Text" },
        { "type": "url", "id": "link_2_url", "label": "Link 2 URL" },
        { "type": "text", "id": "link_3_text", "label": "Link 3 Text" },
        { "type": "url", "id": "link_3_url", "label": "Link 3 URL" },
        { "type": "text", "id": "link_4_text", "label": "Link 4 Text" },
        { "type": "url", "id": "link_4_url", "label": "Link 4 URL" },
        { "type": "text", "id": "link_5_text", "label": "Link 5 Text" },
        { "type": "url", "id": "link_5_url", "label": "Link 5 URL" },
        { "type": "text", "id": "link_6_text", "label": "Link 6 Text" },
        { "type": "url", "id": "link_6_url", "label": "Link 6 URL" },
        { "type": "text", "id": "link_7_text", "label": "Link 7 Text" },
        { "type": "url", "id": "link_7_url", "label": "Link 7 URL" },
        { "type": "text", "id": "link_8_text", "label": "Link 8 Text" },
        { "type": "url", "id": "link_8_url", "label": "Link 8 URL" },
        { "type": "text", "id": "link_9_text", "label": "Link 9 Text" },
        { "type": "url", "id": "link_9_url", "label": "Link 9 URL" },
        { "type": "text", "id": "link_10_text", "label": "Link 10 Text" },
        { "type": "url", "id": "link_10_url", "label": "Link 10 URL" }
      ]
    },
    {
      "type": "social_icon",
      "name": "Social Icon",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Social Icon Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Social Link"
        },
        {
          "type": "range",
          "id": "width",
          "min": 10,
          "max": 100,
          "step": 2,
          "unit": "px",
          "label": "Icon Width",
          "default": 40
        },
        {
          "type": "range",
          "id": "height",
          "min": 10,
          "max": 100,
          "step": 2,
          "unit": "px",
          "label": "Icon Height",
          "default": 40
        }
      ]
    },
    {
      "type": "payment_icon",
      "name": "Payment Icon",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Payment Method Image"
        },
        {
          "type": "range",
          "id": "width",
          "min": 20,
          "max": 150,
          "step": 2,
          "unit": "px",
          "label": "Image Width",
          "default": 50
        },
        {
          "type": "range",
          "id": "height",
          "min": 10,
          "max": 100,
          "step": 2,
          "unit": "px",
          "label": "Image Height",
          "default": 30
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Footer"
    }
  ]
}
{% endschema %}

{{ 'section-custom-footer.css' | asset_url | stylesheet_tag }}
<script src="{{ 'section-custom-footer.js' | asset_url }}" defer="defer"></script>

<footer class="gs-custom-footer reveal-up">
  <!-- 1. Inline Link Groups Section -->
  {%- if section.settings.show_link_groups -%}
    <div class="gs-footer-links-area">
      <div class="gs-footer-container">
        {%- if section.settings.auto_fetch_collections -%}
          <!-- AUTO-FETCH: Loops through all collections and their products -->
          {%- assign excluded_handles = section.settings.excluded_collections | map: 'handle' -%}

          {%- for collection in collections -%}
            <!-- Skip this iteration if the collection is in the excluded list -->
            {%- if excluded_handles contains collection.handle -%}
              {%- continue -%}
            {%- endif -%}

            {%- if collection.products.size > 0 -%}
              <div class="gs-link-group">
                <h4 class="gs-link-group__title">{{ collection.title }}:</h4>
                <ul class="gs-link-group__list">
                  {%- for product in collection.products limit: section.settings.auto_fetch_limit -%}
                    <li>
                      <a href="{{ product.url }}">{{ product.title }}</a>
                    </li>
                  {%- endfor -%}

                  <!-- Fallback 'View All' link if products exceed the limit -->
                  {%- if collection.products.size > section.settings.auto_fetch_limit -%}
                    <li>
                      <a href="{{ collection.url }}">View All {{ collection.title }}...</a>
                    </li>
                  {%- endif -%}
                </ul>
              </div>
            {%- endif -%}
          {%- endfor -%}

        {%- else -%}
          <!-- MANUAL MODE: Uses the blocks configured in the theme editor -->
          {%- for block in section.blocks -%}
            {%- if block.type == 'link_group' -%}
              <div class="gs-link-group" {{ block.shopify_attributes }}>
                {%- if block.settings.title != blank -%}
                  <h4 class="gs-link-group__title">{{ block.settings.title }}</h4>
                {%- endif -%}

                <ul class="gs-link-group__list">
                  {%- if block.settings.menu != blank -%}
                    <!-- Render from Shopify Menu -->
                    {%- for link in block.settings.menu.links -%}
                      <li>
                        <a href="{{ link.url }}">{{ link.title }}</a>
                      </li>
                    {%- endfor -%}
                  {%- else -%}
                    <!-- Render Manual Links -->
                    {%- if block.settings.link_1_text != blank -%}
                      <li>
                        <a href="{{ block.settings.link_1_url }}">{{ block.settings.link_1_text }}</a>
                      </li>
                    {%- endif -%}
                    {%- if block.settings.link_2_text != blank -%}
                      <li>
                        <a href="{{ block.settings.link_2_url }}">{{ block.settings.link_2_text }}</a>
                      </li>
                    {%- endif -%}
                    {%- if block.settings.link_3_text != blank -%}
                      <li>
                        <a href="{{ block.settings.link_3_url }}">{{ block.settings.link_3_text }}</a>
                      </li>
                    {%- endif -%}
                    {%- if block.settings.link_4_text != blank -%}
                      <li>
                        <a href="{{ block.settings.link_4_url }}">{{ block.settings.link_4_text }}</a>
                      </li>
                    {%- endif -%}
                    {%- if block.settings.link_5_text != blank -%}
                      <li>
                        <a href="{{ block.settings.link_5_url }}">{{ block.settings.link_5_text }}</a>
                      </li>
                    {%- endif -%}
                    {%- if block.settings.link_6_text != blank -%}
                      <li>
                        <a href="{{ block.settings.link_6_url }}">{{ block.settings.link_6_text }}</a>
                      </li>
                    {%- endif -%}
                    {%- if block.settings.link_7_text != blank -%}
                      <li>
                        <a href="{{ block.settings.link_7_url }}">{{ block.settings.link_7_text }}</a>
                      </li>
                    {%- endif -%}
                    {%- if block.settings.link_8_text != blank -%}
                      <li>
                        <a href="{{ block.settings.link_8_url }}">{{ block.settings.link_8_text }}</a>
                      </li>
                    {%- endif -%}
                    {%- if block.settings.link_9_text != blank -%}
                      <li>
                        <a href="{{ block.settings.link_9_url }}">{{ block.settings.link_9_text }}</a>
                      </li>
                    {%- endif -%}
                    {%- if block.settings.link_10_text != blank -%}
                      <li>
                        <a href="{{ block.settings.link_10_url }}">{{ block.settings.link_10_text }}</a>
                      </li>
                    {%- endif -%}
                  {%- endif -%}
                </ul>
              </div>
            {%- endif -%}
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}

  <!-- 2. Stats Section -->
  {%- if section.settings.show_stats -%}
    <div class="gs-footer-stats-area">
      <div class="gs-footer-container">
        <div class="gs-stats-flex">
          <!-- Stat Banner / Title -->
          <div class="gs-stats-banner">
            <h3 class="gs-stats-banner__title">Stats</h3>
            <div class="gs-stats-banner__line"></div>
          </div>

          <!-- The 3 Stats -->
          <div class="gs-stats-grid">
            <div class="gs-stat-block">
              <span class="gs-stat-block__number">{{ section.settings.stat_1_num }}</span>
              <span class="gs-stat-block__text">{{ section.settings.stat_1_text }}</span>
            </div>
            <div class="gs-stat-block">
              <span class="gs-stat-block__number">{{ section.settings.stat_2_num }}</span>
              <span class="gs-stat-block__text">{{ section.settings.stat_2_text }}</span>
            </div>
            <div class="gs-stat-block">
              <span class="gs-stat-block__number">
                {{- section.settings.stat_3_num | replace: 'Million', '<span class="gs-stat-small">Million</span>' -}}
              </span>
              <span class="gs-stat-block__text">{{ section.settings.stat_3_text }}</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  {%- endif -%}

  <!-- 3. Bottom Area (Apps, Logo, Socials) -->
  <div class="gs-footer-bottom-area">
    <div class="gs-footer-container">
      <div class="gs-bottom-main-row">
        <!-- Center: Logo -->
        <div class="gs-bottom-logo">
          <a href="{{ routes.root_url }}">
            {%- if section.settings.main_logo != blank -%}
              <img src="{{ section.settings.main_logo | image_url: width: 400 }}" alt="{{ shop.name }}" loading="lazy">
            {%- else -%}
              <h2 class="gs-bottom-logo-text">{{ shop.name }}</h2>
            {%- endif -%}
          </a>
        </div>

        <!-- Right: Social Blocks -->
        <div class="gs-bottom-socials">
          <p class="gs-bottom-heading">{{ section.settings.social_title }}</p>
          <div class="gs-social-badges">
            {%- for block in section.blocks -%}
              {%- if block.type == 'social_icon' and block.settings.image != blank -%}
                <a href="{{ block.settings.link }}" target="_blank" {{ block.shopify_attributes }}>
                  <!-- Native HTML Width/Height attributes strictly used to avoid inline CSS -->
                  <img
                    src="{{ block.settings.image | image_url: width: 200 }}"
                    alt="Social Icon"
                    width="{{ block.settings.width }}"
                    height="{{ block.settings.height }}"
                    loading="lazy"
                    class="gs-custom-icon"
                  >
                </a>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
      </div>

      <!-- 4. Copyright & Payment Blocks -->
      <div class="gs-bottom-copyright-row">
        <p class="gs-copyright">{{ section.settings.copyright_text }}</p>

        {%- if section.settings.show_payments -%}
          <div class="gs-payments-wrapper">
            <span class="gs-payments-title">{{ section.settings.payment_title }}</span>
            <div class="gs-payment-badges">
              {%- for block in section.blocks -%}
                {%- if block.type == 'payment_icon' and block.settings.image != blank -%}
                  <!-- Native HTML Width/Height attributes strictly used to avoid inline CSS -->
                  <img
                    src="{{ block.settings.image | image_url: width: 300 }}"
                    alt="Payment Icon"
                    width="{{ block.settings.width }}"
                    height="{{ block.settings.height }}"
                    loading="lazy"
                    class="gs-custom-icon"
                    {{ block.shopify_attributes }}
                  >
                {%- endif -%}
              {%- endfor -%}
            </div>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</footer>
